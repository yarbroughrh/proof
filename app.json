{
  "expo": {
    "name": "Proof",
    "slug": "proof-solana",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.proof.solana",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Proof needs camera access to capture verifiable photos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Proof uses your location to anchor where a photo was taken."
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-secure-store"
    ]
  }
}
